<?xml version="1.0" ?>
<custom-field-sets xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/trunk/src/Core/System/CustomField/Resources/config/custom-field-sets-1.0.xsd">

    <custom-field-set>
        <name>my_product_custom_fields</name>
        <config>
            <label>Mein Produkt-Feld</label>
            <translated>true</translated>
        </config>

        <relations>
            <entity>product</entity>
        </relations>

        <custom-fields>
            <custom-field>
                <name>extra_note</name>
                <type>text</type>
                <config>
                    <label>Extra Hinweis</label>
                    <componentName>sw-text-field</componentName>
                    <customFieldType>text</customFieldType>
                </config>
            </custom-field>
        </custom-fields>
    </custom-field-set>
</custom-field-sets>
