{% block element_oo_features %}
    {% set config = element.config %}

    <div class="oo-features-wrapper" style="border-radius: 24px;">
        <div class="oo-features-grid" style="
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin: 0 auto;
        ">
            {% for i in 1..4 %}
                {% set name = config['oo-name-' ~ i] is defined ? config['oo-name-' ~ i].value : null %}
                {% set desc = config['oo-desc-' ~ i] is defined ? config['oo-desc-' ~ i].value : null %}
                {% set iconId = config['oo-icon-' ~ i] is defined ? config['oo-icon-' ~ i].value : null %}
                {% set icon = iconId ? getMediaById(iconId) : null %}

                {% if name or desc or icon %}
                    <div class="oo-feature-item">
                        {% if icon %}
                            <div class="oo-feature-icon">
                                <img src="{{ icon.url }}" alt="{{ icon.fileName }}" style="
                                    border-radius: 8px;
                                    width: 48px;
                                    height: 48px;
                                ">
                            </div>
                        {% endif %}
                        <div class="oo-feature-content">
                            {% if name %}
                                <h3 class="oo-feature-title" style="
                                    margin: 0;
                                    font-size: 16px;
                                    font-weight: 600;
                                    color: #222;
                                    line-height: normal;
                                ">{{ name }}</h3>
                            {% endif %}
                            {% if desc %}
                                <p class="oo-feature-desc" style="
                                    margin: 0;
                                    font-size: 14px;
                                    color: #666;
                                    line-height: 1.4;
                                ">{{ desc }}</p>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    <style>
        @media (max-width: 1024px) {
            .oo-features-grid {
                grid-template-columns: repeat(2, 1fr) !important;
            }
        }

        @media (max-width: 767px) {
            .oo-feature-item {
                flex-direction: row !important;
                padding: 16px 12px !important;
            }

            .oo-feature-icon img {
                width: 48px !important;
                height: 48px !important;
            }

            .oo-feature-title {
                font-size: 15px !important;
            }

            .oo-feature-desc {
                font-size: 14px !important;
            }
        }
    </style>
{% endblock %}
